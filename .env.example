# OTEL Log Generator Configuration

CONCURRENCY=1

# Number of messages to send (default: 1)
MESSAGE_COUNT=10

# Minimum interval between started messages in milliseconds (default: 0)
MESSAGE_INTERVAL_MS=100

# Percentage of invalid records to generate 0-100 (default: 0.0)
INVALID_RECORD_PERCENT=0.0

# Number of records per message (default: 1)
RECORDS_PER_MESSAGE=1

# Print detailed logs for each message (default: false)
PRINT_LOGS=false

# Run in continuous mode (default: false)
CONTINUOUS_MODE=false

# Retry configuration for rate limiting (HTTP 429 / gRPC ResourceExhausted)
# Maximum number of retry attempts (0-10, default: 3)
RETRY_MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff (default: 1000)
RETRY_BASE_DELAY_MS=1000

# Maximum delay in milliseconds for exponential backoff (default: 32000)
RETRY_MAX_DELAY_MS=32000

# Ingest endpoint (required)
OTEL_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# Health check endpoint (optional)
OTEL_HEALTHCHECK_ENDPOINT=http://localhost:13133/

# Use protobuf encoding (default: false)
OTEL_USE_PROTOBUF=false

# Transport type: http or grpc (default: http)
OTEL_TRANSPORT=http

# Label cardinality limiting
# Enable/disable limiting (default: true)
OTEL_LABEL_CARDINALITY_ENABLED=true

# Default limit for keys not listed below (optional)
# OTEL_LABEL_CARDINALITY_DEFAULT_LIMIT=32

# Per-key limits as CSV map key=limit,key2=limit2
# Safe defaults are applied automatically for:
# k8s.pod.name=32,host.name=16,service.version=32,request.id=64,thread.id=32,user.id=64
OTEL_LABEL_CARDINALITY_LIMITS=k8s.pod.name=32,host.name=16,service.version=32,request.id=64,thread.id=32,user.id=64

# Tenant routing
# Single-tenant mode defaults to "default".
TENANT_ID=default
# Multi-tenant mode switch. When > 1, routing uses tenant1..tenantN and ignores TENANT_ID.
TENANT_COUNT=1

# Number of cloud.account.id values generated inside each tenant-local pool (default: 4)
CLOUD_ACCOUNT_COUNT_PER_TENANT=4

# Number of service.name values generated inside each tenant-local pool (default: 6)
SERVICE_COUNT_PER_TENANT=6

# Jitter window applied to each log record timestamp in milliseconds (0 to disable, default: 1000 = 1s)
RECORD_TIMESTAMP_JITTER_MS=1000
